# Copy this file to .env.docker and edit as needed.
# Usage: docker compose --env-file .env.docker up --build

# ---- Ports (host-side mappings) ----
FRONTEND_PORT=3000
BACKEND_PORT=8080

# ---- Backend ----
# GitHub personal access token (optional but improves rate limits).
# Leave empty to skip the GitHub provider.
GITHUB_TOKEN=

# Which news providers to activate (comma-separated).
# Options: mock, rss, hackernews, github, reddit
ACTIVE_PROVIDERS=rss,hackernews,reddit
